{
  "name": "codjiflo-action",
  "version": "1.0.0",
  "description": "GitHub Action for CodjiFlo iteration tracking",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "node ../scripts/generate-schema.cjs",
    "build": "ncc build src/index.ts -o dist --license licenses.txt",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@codjiflo/diff-engine": "file:../packages/diff-engine",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.5.0",
    "pino": "^10.1.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.0",
    "node-gyp": "^12.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.16"
  }
}
