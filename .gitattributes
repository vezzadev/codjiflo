# Auto-detect text files and normalize line endings to LF in the repo
* text=auto

# Force LF for files that npm/node generate
package-lock.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.sh text eol=lf
