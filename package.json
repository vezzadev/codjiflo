{
  "name": "codjiflo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/ensure-env.js && next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:storybook": "vitest --config=vitest.storybook.config.ts",
    "test:e2e": "cross-env E2E_DEPENDENCIES_MODE=mock playwright test",
    "test:e2e:prod": "cross-env E2E_DEPENDENCIES_MODE=prod playwright test",
    "test:e2e:headed": "cross-env E2E_DEPENDENCIES_MODE=mock playwright test --headed",
    "test:e2e:ui": "cross-env E2E_DEPENDENCIES_MODE=mock playwright test --ui",
    "test:e2e:debug": "cross-env E2E_DEPENDENCIES_MODE=mock playwright test --debug",
    "test:all": "npm run lint && npm run typecheck && npm run test:coverage && npm run test:e2e && npm run test:storybook"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "diff-match-patch": "^1.0.5",
    "next": "^15.1.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "react-window": "^2.2.3",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.9"
  },
  "overrides": {
    "@swc/helpers": "^0.5.15",
    "esbuild": "^0.25.0",
    "path-to-regexp": "^8.0.0",
    "undici": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-vitest": "^10.1.10",
    "@storybook/react": "^10.1.5",
    "@storybook/react-vite": "^10.1.10",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.32.0",
    "eslint-config-next": "^16.1.1",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^10.1.5",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "storybook": "^10.1.10",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.50.1",
    "vercel": "^50.1.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.16"
  }
}
