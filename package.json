{
  "name": "codjiflo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/copy-sql-wasm.js",
    "dev": "node scripts/ensure-env.js && next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --fix --quiet",
    "lint:check": "eslint . --quiet",
    "storybook": "storybook dev -p 6006 --quiet",
    "build-storybook": "storybook build --quiet",
    "typecheck": "tsc --noEmit",
    "test": "vitest --reporter=dot",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch --reporter=dot",
    "test:coverage": "vitest --coverage --coverage.reporter=text --coverage.reporter=json --coverage.reporter=json-summary --coverage.reporter=html --reporter=dot",
    "test:storybook": "vitest --config=vitest.storybook.config.ts --reporter=dot",
    "test:e2e": "cross-env E2E_DEPENDENCIES_MODE=mock playwright test --reporter=dot",
    "test:e2e:prod": "cross-env E2E_DEPENDENCIES_MODE=prod playwright test --reporter=dot",
    "test:e2e:headed": "cross-env E2E_DEPENDENCIES_MODE=mock playwright test --headed --reporter=dot",
    "test:e2e:ui": "cross-env E2E_DEPENDENCIES_MODE=mock playwright test --ui",
    "test:e2e:debug": "cross-env E2E_DEPENDENCIES_MODE=mock playwright test --debug",
    "test:all": "npm run lint -s && npm run typecheck -s && npm run test -s -- --coverage && npm run test:e2e -s && npm run test:storybook -s"
  },
  "dependencies": {
    "diff-match-patch": "^1.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "next": "^16.1.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "react-window": "^2.2.4",
    "sql.js": "^1.11.0",
    "zustand": "^5.0.9"
  },
  "overrides": {
    "@swc/helpers": "^0.5.15",
    "esbuild": "^0.25.0",
    "path-to-regexp": "^8.0.0",
    "undici": "^6.0.0"
  },
  "browserslist": {
    "production": [
      "chrome >= 90",
      "edge >= 90",
      "firefox >= 88",
      "safari >= 14",
      "ios_saf >= 14"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-vitest": "^10.1.11",
    "@storybook/react": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "autoprefixer": "^10.4.23",
    "better-sqlite3": "^12.5.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.32.0",
    "eslint-config-next": "^16.1.1",
    "eslint-plugin-playwright": "^2.4.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^10.1.11",
    "globals": "^17.0.0",
    "jsdom": "^27.3.0",
    "pino": "^10.1.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "storybook": "^10.1.10",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.52.0",
    "vercel": "^50.1.6",
    "vite": "^7.2.7",
    "vitest": "^4.0.17"
  }
}
